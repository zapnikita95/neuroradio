{
  "name": "music-story-bff",
  "version": "1.0.0",
  "description": "BFF for Music Story APK — story generation, TTS, and metadata enrichment",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc && node -e \"const fs=require('fs'); fs.mkdirSync('dist/data',{recursive:true}); for (const f of ['known-artists.json','curated-facts.json','cover-classics.json','popular-tracks-catalog.json','facts-bank-seed.json','solo-artist-grammar.json','german-pronunciation.json','french-pronunciation.json','artist-pronunciation.json','style-corpus-seed.jsonl']) { const s='src/data/'+f; if(fs.existsSync(s)) fs.copyFileSync(s,'dist/data/'+f); }\"",
    "test:fr-phonetic": "npm run build && node scripts/test-fr-phonetic.mjs",
    "typecheck": "tsc --noEmit",
    "test:gemini": "npm run build && node scripts/test-live-gemini-story.mjs",
    "test:gemini:prod": "node scripts/test-production-gemini.mjs",
    "test:quality": "npm run build && node scripts/test-story-quality.mjs",
    "test:tts": "npm run build && node scripts/test-tts-pipeline.mjs",
    "test:mobile-wav": "npm run build && node scripts/test-mobile-wav-routing.mjs",
    "test:en-phonetic": "npm run build && node scripts/test-en-phonetic-ru.mjs",
    "test:de-phonetic": "npm run build && node scripts/test-de-phonetic.mjs",
    "demo:hit-co": "npm run build && node scripts/demo-hit-co-tts.mjs",
    "demo:audio": "npm run build && node scripts/demo-audio-all.mjs",
    "demo:android-tts": "npm run build && node scripts/demo-android-tts.mjs",
    "test:tts:voices": "npm run build && node scripts/test-all-voices-tts.mjs",
    "test:elevenlabs-narrators": "npm run build && node scripts/test-elevenlabs-narrators.mjs",
    "test:elevenlabs-foreign": "npm run build && node scripts/test-elevenlabs-foreign.mjs",
    "generate:website-demos-en": "node scripts/generate-website-demos-en.mjs --preview",
    "generate:website-demos-en:all": "node scripts/generate-website-demos-en.mjs --all",
    "test:fact-sources": "npm run build && node scripts/benchmark-fact-sources.mjs",
    "build:catalog": "node scripts/build-popular-tracks-catalog.mjs --target=60000 --no-proxy",
    "build:catalog:20k": "node scripts/build-popular-tracks-catalog.mjs --target=20000 --no-proxy",
    "build:catalog:10k": "node scripts/build-popular-tracks-catalog.mjs --target=10000 --no-proxy",
    "seed:facts": "node scripts/bulk-seed-fact-bank.mjs --target=60000 --hot-target=20000 --concurrency=3 --resume --no-proxy --backfill-discogs",
    "seed:facts:discogs": "node scripts/bulk-seed-fact-bank.mjs --target=60000 --hot-target=20000 --concurrency=1 --resume --no-proxy --discogs-only --backfill-discogs",
    "test:facts": "npm run build && node scripts/test-fact-topic.mjs && node scripts/test-live-facts-5tracks.mjs",
    "test:fact-pick": "npm run build && node scripts/test-fact-pick-regression.mjs",
    "test:similar-tracks": "npm run build && node scripts/test-similar-tracks-regression.mjs",
    "verify:track": "npm run build && node scripts/verify-story-track.mjs",
    "verify:batch": "npm run build && node scripts/verify-story-batch.mjs",
    "audit:bulk": "npm run build && node scripts/audit-bulk-coverage.mjs",
    "seed:facts:retry-zero": "node scripts/bulk-seed-fact-bank.mjs --target=60000 --hot-target=20000 --concurrency=3 --resume --retry-zero --no-proxy --backfill-discogs",
    "harvest:charts": "npm run build && node scripts/weekly-chart-harvest.mjs",
    "harvest:charts:dry": "npm run build && node scripts/weekly-chart-harvest.mjs --dry-run",
    "harvest:charts:status": "npm run build && node scripts/chart-harvest-status.mjs",
    "expand:catalog": "npm run build && node scripts/merge-trending-into-catalog.mjs"
  },
  "keywords": [
    "music",
    "story",
    "bff",
    "express"
  ],
  "license": "MIT",
  "dependencies": {
    "cmu-pronouncing-dictionary": "^3.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "edge-tts-universal": "^1.4.0",
    "express": "^4.21.2",
    "jose": "^5.10.0",
    "node-fetch": "^3.3.2",
    "pg": "^8.13.1",
    "phonemize": "^1.2.0",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
