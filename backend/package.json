{
  "name": "music-story-bff",
  "version": "1.0.0",
  "description": "BFF for Music Story APK — story generation, TTS, and metadata enrichment",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc && node -e \"const fs=require('fs'); fs.mkdirSync('dist/data',{recursive:true}); for (const f of ['known-artists.json','curated-facts.json','cover-classics.json','solo-artist-grammar.json']) { const s='src/data/'+f; if(fs.existsSync(s)) fs.copyFileSync(s,'dist/data/'+f); }\"",
    "typecheck": "tsc --noEmit",
    "test:gemini": "npm run build && node scripts/test-live-gemini-story.mjs",
    "test:gemini:prod": "node scripts/test-production-gemini.mjs",
    "test:quality": "npm run build && node scripts/test-story-quality.mjs",
    "test:tts": "npm run build && node scripts/test-tts-pipeline.mjs",
    "test:en-phonetic": "npm run build && node scripts/test-en-phonetic-ru.mjs",
    "demo:hit-co": "npm run build && node scripts/demo-hit-co-tts.mjs",
    "test:tts:voices": "npm run build && node scripts/test-all-voices-tts.mjs",
    "test:fact-sources": "npm run build && node scripts/benchmark-fact-sources.mjs"
  },
  "keywords": [
    "music",
    "story",
    "bff",
    "express"
  ],
  "license": "MIT",
  "dependencies": {
    "cmu-pronouncing-dictionary": "^3.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "edge-tts-universal": "^1.4.0",
    "express": "^4.21.2",
    "node-fetch": "^3.3.2",
    "pg": "^8.13.1",
    "phonemize": "^1.2.0",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
