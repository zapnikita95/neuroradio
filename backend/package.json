{
  "name": "music-story-bff",
  "version": "1.0.0",
  "description": "BFF for Music Story APK — story generation, TTS, and metadata enrichment",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc && node -e \"const fs=require('fs'); fs.mkdirSync('dist/data',{recursive:true}); if(fs.existsSync('src/data/known-artists.json')) fs.copyFileSync('src/data/known-artists.json','dist/data/known-artists.json');\"",
    "typecheck": "tsc --noEmit",
    "test:gemini": "npm run build && node scripts/test-live-gemini-story.mjs",
    "test:gemini:prod": "node scripts/test-production-gemini.mjs",
    "test:quality": "npm run build && node scripts/test-story-quality.mjs",
    "test:tts": "npm run build && node scripts/test-tts-pipeline.mjs"
  },
  "keywords": ["music", "story", "bff", "express"],
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "node-fetch": "^3.3.2",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
