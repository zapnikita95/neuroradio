# Groq API — story generation (https://console.groq.com/keys)
GROQ_API_KEY=

# Optional overrides (defaults work out of the box):
# AUTH_JWT_SECRET=          # auto-derived from GROQ_API_KEY if omitted
# ALLOWED_CERT_SHA256=      # add Play Store release cert; debug cert built-in
# ALLOW_DEBUG_CERT=false    # disable debug APK cert on public production
# ALLOWED_PACKAGE_NAME=com.musicstory.app
# ALLOWED_IOS_TEAM_ID=      # Apple Team ID for iOS app (developer.apple.com → Membership)

# Desktop app auth (Tauri widget)
# DESKTOP_AUTH_SECRET=      # min 16 chars; sent by desktop client on /v1/auth/token
# ALLOW_DESKTOP_AUTH=true   # dev-only: allow desktop tokens without secret

# Linked account storage (phone + desktop sync codes, settings, history)
# ACCOUNT_DATA_DIR=./data    # on Railway mount a volume here for persistence
# UNLIMITED_INSTALL_IDS=uuid1,uuid2   # skip story rate limits for these devices

# Yandex Cloud SpeechKit — TTS synthesis (optional)
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# Server port (default 3000; Railway sets PORT automatically)
PORT=3000
