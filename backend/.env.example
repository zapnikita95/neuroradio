# Groq API — story generation (https://console.groq.com/keys)
GROQ_API_KEY=

# Gemini API — story generation (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Free-tier model only: gemini-2.0-flash-lite (recommended)
GEMINI_MODEL=gemini-2.0-flash-lite

# OpenRouter — https://openrouter.ai/keys
OPEN_ROUTER_API_KEY=

# LLM provider on server: openrouter | groq | gemini | local
LLM_PROVIDER=openrouter

# Local Ollama (ZeroTier / LAN) — when LLM_PROVIDER=local
# LOCAL_OLLAMA_BASE_URL=http://127.0.0.1:11435
# LOCAL_OLLAMA_MODEL=qwen3.6:35b-a3b-q4_K_M

# Groq model — only if LLM_PROVIDER=groq
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional overrides (defaults work out of the box):
# AUTH_JWT_SECRET=          # auto-derived from GROQ_API_KEY if omitted
# USER_SECRETS_ENCRYPTION_KEY=  # AES key for user API keys at rest (32+ chars); falls back to AUTH_JWT_SECRET / GROQ_API_KEY
# ALLOWED_CERT_SHA256=      # add Play Store release cert; debug cert built-in
# ALLOW_DEBUG_CERT=false    # disable debug APK cert on public production
# ALLOWED_PACKAGE_NAME=com.musicstory.app
# ALLOWED_IOS_TEAM_ID=      # Apple Team ID for iOS app (developer.apple.com → Membership)

# Desktop app auth (Tauri widget)
# DESKTOP_AUTH_SECRET=      # min 16 chars; sent by desktop client on /v1/auth/token
# ALLOW_DESKTOP_AUTH=true   # dev-only: allow desktop tokens without secret

# Linked account storage (phone + desktop sync codes, settings, history)
# ACCOUNT_DATA_DIR=./data    # on Railway mount a volume here for facts-bank (JSON)
# DATABASE_URL=postgresql://...   # Railway Postgres — accounts, auth, feedback, fact-misses, dev-tier
# PG_POOL_MAX=20                  # Postgres pool size (default 20, max 50)
# FACT_BANK_SAVE_DEBOUNCE_MS=3000 # debounce facts-bank.json writes on live BFF (ms)
# UNLIMITED_INSTALL_IDS=uuid1,uuid2   # skip story rate limits for these devices

# Story quotas per tier (defaults: free 3/day, trial 10/mo + 10/day, premium 25/day)
# FREE_STORY_DAILY_LIMIT=10
# TRIAL_STORY_DAILY_LIMIT=10
# PREMIUM_STORY_DAILY_LIMIT=25
# ALLOW_DEV_TIER_SWITCH=true
# OpenRouter: free tier — paid Gemma 4 (~$0.06/M, stable). Trial/premium — DeepSeek V3.
# OPENROUTER_FREE_STORY_MODEL=google/gemma-4-26b-a4b-it
# OPENROUTER_FREE_FACT_MODEL=google/gemma-4-26b-a4b-it
# OPENROUTER_FREE_LEGACY=true   # вернуть :free Gemma/Nemotron chain (429)
# OPENROUTER_FACT_MODEL=deepseek/deepseek-chat-v3-0324
# OPENROUTER_STORY_MODEL=deepseek/deepseek-chat-v3-0324

# Account login (email OTP via Resend + Telegram Login Widget)
# RESEND_API_KEY=re_...           # https://resend.com/api-keys
# RESEND_FROM=Music Story <noreply@yourdomain.com>   # verified domain in Resend
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=       # без @
# TELEGRAM_BOT_ID=             # опционально; иначе префикс токена до :
# TELEGRAM_OIDC_CLIENT_SECRET= # BotFather → бот → Login → Client secret (OAuth, как Movie Planner)
# TELEGRAM_OAUTH_REDIRECT_URI=https://www.efir-ai.ru/v1/public/oauth/telegram/callback-bridge
# TELEGRAM_WIDGET_BASE_URL=https://www.efir-ai.ru
# Without Resend codes are logged to server console (dev only)

# Marketing website (efir-ai.ru) served as static by the backend
# WEBSITE_DIR=                  # override path to website/ (auto-detected by default)
# SITE_URL=https://efir-ai.ru   # used in subscribe emails
# GITHUB_REPO=zapnikita95/neuroradio   # source of latest APK/extension release links
# POST /v1/public/subscribe emails APK + extension download links via Resend (see above)
# APP_STORE_URL=                  # https://apps.apple.com/app/idXXXXXXXXX (после публикации в App Store)
# GOOGLE_PLAY_URL=                # https://play.google.com/store/apps/details?id=com.efirai.myapp

# Yandex Cloud SpeechKit — TTS synthesis (optional)
# YANDEX_API_KEY=
# YANDEX_FOLDER_ID=

# Enhanced TTS pipeline
# TTS_AUDIO_POSTPROCESS=true   # ffmpeg loudness/EQ (default on in production)
# PREMIUM_INSTALL_IDS=uuid     # test premium without Play Billing

# Premium voice — SaluteSpeech / Сбер (РФ, см. backend/SALUTE_SPEECH.md)
# SALUTE_SPEECH_AUTH_KEY=       # Authorization Key из Studio
# SALUTE_SPEECH_SCOPE=SALUTE_SPEECH_PERS
# SALUTE_SPEECH_ENABLED=true
# SALUTE_SPEECH_VOICE=Pon_24000
# SALUTE_SPEECH_FORMAT=opus
# SALUTE_SPEECH_CA_CERT=        # russian_trusted_root_ca.pem для Node на Railway

# Опционально (часто недоступно из РФ):
# AZURE_SPEECH_KEY= / AZURE_SPEECH_REGION=

# ElevenLabs — English premium TTS only (расширенный тариф, не trial)
# ELEVENLABS_API_KEY=
# ELEVENLABS_ENABLED=true
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Billing admin (dev): POST /v1/billing/activate-admin with header x-billing-admin-secret
# BILLING_ADMIN_SECRET=

# ЮKassa — оплата подписки с сайта и приложения
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
# YOOKASSA_RETURN_URL=https://www.efir-ai.ru/?payment=success
# Webhook в кабинете ЮKassa: https://ТВОЙ-BFF.up.railway.app/v1/public/yookassa/webhook

# Google Play — verify USD subscriptions (JSON service account, one line)
# GOOGLE_PLAY_PACKAGE_NAME=com.efirai.myapp
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# App Store — verify USD subscriptions
# Legacy receipt verify (Shared Secret from App Store Connect → app-specific shared secret):
# APP_STORE_SHARED_SECRET=
# StoreKit 2 server verify + webhooks (Connect → Users and Access → Integrations → In-App Purchase key):
# APPLE_KEY_ID=
# APPLE_ISSUER_ID=
# APPLE_IAP_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# APPLE_BUNDLE_ID=com.efirai.myapp
# Webhook in App Store Connect (Эфир AI app → App Information):
#   Production + Sandbox: https://www.efir-ai.ru/v1/public/app-store/notifications

# Resend — письма с ссылкой на оплату, чеки (https://resend.com)
# RESEND_API_KEY=
# RESEND_FROM=Эфир AI <hello@efir-ai.ru>
# RECEIPT_ADMIN_EMAIL=zap.nikita95@gmail.com
# PUBLIC_BFF_URL=https://www.efir-ai.ru

# Локально из РФ: hidemy.name VPN → авто-прокси 127.0.0.1:1301 (Groq, Gemini, Last.fm, ElevenLabs, …).
# Вручную, если нужно: HTTP_PROXY=http://127.0.0.1:1301  HTTPS_PROXY=http://127.0.0.1:1301

# Fact harvest (локальный npm run seed:facts; на Railway — банк + weekly charts)
# GENIUS_ACCESS_TOKEN=
# LASTFM_API_KEY=
# SETLISTFM_API_KEY=
# DISCOGS_TOKEN=   # https://www.discogs.com/settings/developers (60 req/min)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_SECRET=              # Railway name; SPOTIFY_CLIENT_SECRET also accepted
# Note: Spotify playlist API returns 403 without Premium on app owner — charts use Deezer instead.
# WEEKLY_CHART_HARVEST=true   # opt-in; off by default (do not steal API from story/full)
# WEEKLY_CHART_HARVEST_DELAY_MS=10800000  # first run 3h after boot (default)
# HARVEST_RATE_LIMIT=true       # only bulk-seed / chart-harvest scripts (never on live BFF)
# FACT_FETCH_HARD_CAP_MS=9000   # per-source timeout in parallel fact harvest (live default 9s)
# FACT_FETCH_TIMEOUT_MS=12000   # soft log budget when fetch phase is slow
# FACT_WIKI_CAP_MS=7000
# FACT_WIKI_FAST_CAP_MS=8000
# WEEKLY_CHART_HARVEST_LIMIT=60   # max new tracks to harvest per run
# WEEKLY_CHART_HARVEST_CONCURRENCY=2

# Weekly deep enrich (Sunday 03:00 MSK) — boring-feedback + RU zero + era-top100
# WEEKLY_DEEP_ENRICH=true
# WEEKLY_DEEP_ENRICH_CAP=50          # tracks per week (Railway: set yourself)
# WEEKLY_DEEP_ENRICH_DELAY_MS=21600000  # first run 6h after boot; then every Sunday
# DEEP_ENRICH_MODE=ddg_jina          # baseline_ddg | ddg_jina (default, free) | tavily | perplexity
# DEEP_ENRICH_LLM_VERIFY=false       # heuristic only in bulk (~$0); true adds ~$0.005/fact
# TELEGRAM_ADMIN_CHAT_ID=            # numeric chat id — weekly win digest to auth bot

# Server port (default 3000; Railway sets PORT automatically)
PORT=3000
