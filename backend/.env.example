# Groq API — story generation (https://console.groq.com/keys)
GROQ_API_KEY=

# Gemini API — story generation (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Free-tier model only: gemini-2.0-flash-lite (recommended)
GEMINI_MODEL=gemini-2.0-flash-lite

# OpenRouter — https://openrouter.ai/keys
OPEN_ROUTER_API_KEY=

# LLM provider on server: openrouter | groq | gemini | local
LLM_PROVIDER=openrouter

# Local Ollama (ZeroTier / LAN) — when LLM_PROVIDER=local
# LOCAL_OLLAMA_BASE_URL=http://127.0.0.1:11435
# LOCAL_OLLAMA_MODEL=qwen3.6:35b-a3b-q4_K_M

# Groq model — only if LLM_PROVIDER=groq
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional overrides (defaults work out of the box):
# AUTH_JWT_SECRET=          # auto-derived from GROQ_API_KEY if omitted
# ALLOWED_CERT_SHA256=      # add Play Store release cert; debug cert built-in
# ALLOW_DEBUG_CERT=false    # disable debug APK cert on public production
# ALLOWED_PACKAGE_NAME=com.musicstory.app
# ALLOWED_IOS_TEAM_ID=      # Apple Team ID for iOS app (developer.apple.com → Membership)

# Desktop app auth (Tauri widget)
# DESKTOP_AUTH_SECRET=      # min 16 chars; sent by desktop client on /v1/auth/token
# ALLOW_DESKTOP_AUTH=true   # dev-only: allow desktop tokens without secret

# Linked account storage (phone + desktop sync codes, settings, history)
# ACCOUNT_DATA_DIR=./data    # on Railway mount a volume here for facts-bank (JSON)
# DATABASE_URL=postgresql://...   # Railway Postgres — accounts, auth, feedback, fact-misses, dev-tier
# UNLIMITED_INSTALL_IDS=uuid1,uuid2   # skip story rate limits for these devices

# Story quotas per tier (defaults: free 3/day, trial 10/mo + 10/day, premium 25/day)
# FREE_STORY_DAILY_LIMIT=10
# TRIAL_STORY_DAILY_LIMIT=10
# PREMIUM_STORY_DAILY_LIMIT=25
# ALLOW_DEV_TIER_SWITCH=true
# OpenRouter: free tier uses Gemma 4 :free (fact) + Liquid :free (story); trial/premium use DeepSeek V3
# OPENROUTER_FACT_MODEL=deepseek/deepseek-chat-v3-0324
# OPENROUTER_STORY_MODEL=deepseek/deepseek-chat-v3-0324

# Account login (email OTP via Resend + Telegram Login Widget)
# RESEND_API_KEY=re_...           # https://resend.com/api-keys
# RESEND_FROM=Music Story <noreply@yourdomain.com>   # verified domain in Resend
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=       # без @
# TELEGRAM_WIDGET_BASE_URL=https://efir-ai.ru   # @BotFather /setdomain → efir-ai.ru
# Without Resend codes are logged to server console (dev only)

# Yandex Cloud SpeechKit — TTS synthesis (optional)
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# Enhanced TTS pipeline
# TTS_AUDIO_POSTPROCESS=true   # ffmpeg loudness/EQ (default on in production)
# PREMIUM_INSTALL_IDS=uuid     # test premium without Play Billing

# Premium voice — SaluteSpeech / Сбер (РФ, см. backend/SALUTE_SPEECH.md)
# SALUTE_SPEECH_AUTH_KEY=       # Authorization Key из Studio
# SALUTE_SPEECH_SCOPE=SALUTE_SPEECH_PERS
# SALUTE_SPEECH_ENABLED=true
# SALUTE_SPEECH_VOICE=Pon_24000
# SALUTE_SPEECH_FORMAT=opus
# SALUTE_SPEECH_CA_CERT=        # russian_trusted_root_ca.pem для Node на Railway

# Опционально (часто недоступно из РФ):
# AZURE_SPEECH_KEY= / AZURE_SPEECH_REGION=
# ELEVENLABS_API_KEY= / ELEVENLABS_ENABLED=false

# Billing admin (dev): POST /v1/billing/activate-admin with header x-billing-admin-secret
# BILLING_ADMIN_SECRET=

# Server port (default 3000; Railway sets PORT automatically)
PORT=3000
