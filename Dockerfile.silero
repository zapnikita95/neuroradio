# Silero TTS for Railway (navatusein/silero-tts-service).
FROM navatusein/silero-tts-service:latest

WORKDIR /usr/app
COPY silero-railway-entrypoint.py ./silero-railway-entrypoint.py

ENV LANGUAGE=ru
ENV NUMBER_OF_THREADS=4
ENV SAMPLE_RATE=48000

EXPOSE 8080
CMD ["python3", "-u", "./silero-railway-entrypoint.py"]
