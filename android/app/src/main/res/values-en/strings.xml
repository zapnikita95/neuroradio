    <string name="onboarding_title">Notification access</string>
    <string name="onboarding_welcome_headline">AI radio host for Spotify and Yandex Music</string>
    <string name="onboarding_welcome_subtitle">Voice stories about the track that is playing — without leaving your music app.</string>
    <string name="onboarding_apk_faq_title">Installed outside Google Play?</string>
    <string name="onboarding_apk_faq_body">If you sideloaded the app, Android may block notification access.\n\nDo this once:\n1. Settings → Apps → Broadcast AI\n2. Menu (⋮) → Allow restricted settings\n3. Special app access → Notification access → turn on \"Broadcast AI — media monitoring\"\n\nOn Samsung, Xiaomi, and Honor the exact menu names may differ, but the order is the same: lift the app restriction first, then grant notification access.</string>
    <string name="onboarding_open_app_settings">Open app info</string>
    <string name="onboarding_description">Broadcast AI reads track info from Spotify and Yandex Music through notification access. Without it, the app cannot tell what is playing.</string>
    <string name="onboarding_steps">1. If you sideloaded the APK, complete the steps in the section above first.\n2. Tap \"Open notification access\" below.\n3. Turn on \"Broadcast AI — media monitoring\".\n4. Return here and tap \"Check and continue\".</string>
    <string name="onboarding_open_settings">Open notification access</string>
    <string name="onboarding_check_access">Check and continue</string>
    <string name="onboarding_not_granted_yet">Turn on \"Broadcast AI — media monitoring\" first. If you sideloaded the APK, enable Allow restricted settings in App info.</string>
    <string name="home_tour_welcome_title">Welcome to Broadcast AI</string>
    <string name="home_tour_welcome_body">First week — full access: ElevenLabs voices, best models, offline stories. Then — Basic with Edge TTS; Extended by subscription. Stories are voiced in your chosen persona — every broadcast is unique.</string>
    <string name="home_tour_track_title">Now playing</string>
    <string name="home_tour_track_body">When you play a track in Spotify or Yandex Music, it shows here — title, artist, and source.</string>
    <string name="home_tour_counter_title">Next story</string>
    <string name="home_tour_counter_body">In automatic mode this shows how many tracks until the next story.</string>
    <string name="home_tour_story_btn_title">Tell the story</string>
    <string name="home_tour_story_btn_body">Start a story manually anytime — the app prepares text and voices it.</string>
    <string name="home_tour_settings_title">Settings</string>
    <string name="home_tour_settings_body">Mode, voice, story length, AI model, and more. We will walk through them now.</string>
    <string name="home_tour_history_title">History</string>
    <string name="home_tour_history_body">All stories and listened tracks are saved here.</string>
    <string name="tour_step_mode_title">Operating mode</string>
    <string name="tour_step_mode_body">Automatic — stories on a track counter. Manual — only the «Tell the story» button. The first real track after install also gets a story.</string>
    <string name="tour_step_trigger_title">When to insert a story</string>
    <string name="tour_step_trigger_body">Every N tracks — your auto setting. Or specific artists, genres, always, or never.</string>
    <string name="tour_step_same_track_title">Same track repeat</string>
    <string name="tour_step_same_track_body">If one track loops in a playlist — no spam: at most one story per N plays.</string>
    <string name="tour_step_narrator_title">Narrator</string>
    <string name="tour_step_narrator_body">Tone of delivery: expert, DJ, superfan. Affects style, not Wikipedia facts.</string>
    <string name="tour_step_voice_title">Voice and length</string>
    <string name="tour_step_voice_body">Server voiceover: voice, emotion, speed. Story length — how long the host speaks.</string>
    <string name="tour_step_music_title">Music during story</string>
    <string name="tour_step_music_body">Pause starts when voiceover begins, not before. Fade — smooth ducking before speech.</string>
    <string name="tour_step_ai_title">AI model</string>
    <string name="tour_step_ai_body">DeepSeek V3 — best for facts on subscription. Free — Llama 3.3 on the server. Your OpenRouter key removes server limits.</string>
