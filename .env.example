# Groq API — story generation (https://console.groq.com/keys)
GROQ_API_KEY=

# Gemini API — story generation (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# LLM provider on server: groq | gemini (default groq)
LLM_PROVIDER=groq
# Primary Groq model (default llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Optional overrides (JWT auth is automatic from GROQ_API_KEY):
# AUTH_JWT_SECRET=
# ALLOWED_CERT_SHA256=
# ALLOWED_IOS_TEAM_ID=

# Yandex Cloud SpeechKit — TTS synthesis (optional)
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# Server port (default 3000)
PORT=3000
