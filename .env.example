# Groq API — story generation (https://console.groq.com/keys)
GROQ_API_KEY=

# Gemini API — story generation (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# OpenRouter — https://openrouter.ai/keys (на Railway только ключ; модель — в приложении)
OPEN_ROUTER_API_KEY=

# LLM provider on server: openrouter | groq | gemini
LLM_PROVIDER=openrouter
# Groq model — только если llm_provider=groq (или свой groq_model из приложения)
GROQ_MODEL=llama-3.3-70b-versatile

# Optional overrides (JWT auth is automatic from GROQ_API_KEY):
# AUTH_JWT_SECRET=
# ALLOWED_CERT_SHA256=
# ALLOWED_IOS_TEAM_ID=

# Yandex Cloud SpeechKit — TTS synthesis (optional)
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# Server port (default 3000)
PORT=3000

# iOS TestFlight — Spotify App Remote (https://developer.spotify.com/dashboard)
# Redirect URI в Dashboard: efirai://spotify-callback
SPOTIFY_CLIENT_ID=
